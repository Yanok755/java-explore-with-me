                  "    pm.expect(jsonData.length).to.be.greaterThan(0);",
                  "    pm.expect(jsonData[0]).to.have.property('id');",
                  "    pm.expect(jsonData[0]).to.have.property('text');",
                  "    pm.expect(jsonData[0]).to.have.property('author');",
                  "});"
                ],
